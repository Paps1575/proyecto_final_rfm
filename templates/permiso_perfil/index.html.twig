{% extends 'base.html.twig' %}

{% block title %}Matriz de Permisos - Funes Mori Productions{% endblock %}

{% block body %}
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mt-3">
        <div class="card-header bg-white border-0 py-4 px-4">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-shield-lock-fill text-primary fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0 text-dark text-uppercase">Matriz de Permisos</h3>
                        <p class="text-muted small mb-0 italic">Gestión de privilegios por perfil &copy; 2026</p>
                    </div>
                </div>
                {# Indicador de carga sutil #}
                <div id="loaderGlobal" class="spinner-border text-primary d-none" role="status"></div>
            </div>
        </div>

        <div class="card-body p-4 pt-0">
            <hr class="opacity-10 mb-4">

            {# Selector de Perfil #}
            <div class="bg-light p-4 rounded-4 border mb-4 shadow-sm border-2 border-primary border-opacity-10">
                <label class="fw-bold small mb-2 text-uppercase text-muted">Seleccione el perfil a configurar:</label>
                <select id="selectPerfil" class="form-select form-select-lg border-2 shadow-sm fw-bold text-primary rounded-3">
                    <option value="">-- ELIJA UN ROL DEL SISTEMA --</option>
                    {% for p in perfiles %}
                        <option value="{{ p.id }}">{{ p.strNombrePerfil|upper }}</option>
                    {% endfor %}
                </select>
            </div>

            {% set es_editor = is_granted('MODULO_EDITAR', 'PERMISOS PERFIL') %}

            {# Formulario Maestro #}
            <form action="{{ path('app_permiso_perfil_bulk_update') }}" method="POST" id="formMatriz">
                {# Token CSRF fundamental para que Railway no te rebote el POST #}
                <input type="hidden" name="_token" value="{{ csrf_token('permisos_bulk_update') }}">
                {# Campo oculto para saber qué perfil estamos guardando #}
                <input type="hidden" name="perfil_id" id="perfil_id_hidden" value="">

                <div class="table-responsive rounded-3 border shadow-sm">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                        <tr>
                            <th class="px-4 py-3">Módulo</th>
                            <th class="text-center">Agregar</th>
                            <th class="text-center">Editar</th>
                            <th class="text-center">Eliminar</th>
                            <th class="text-center">Consultar</th>
                            <th class="text-center" style="width: 80px;">Estado</th>
                        </tr>
                        </thead>
                        <tbody id="tablaPermisos">
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="opacity-50">
                                    <i class="bi bi-arrow-up-circle d-block fs-1 mb-2"></i>
                                    <span class="italic fs-5">Seleccione un perfil para cargar la matriz...</span>
                                </div>
                            </td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                {% if es_editor %}
                    <div id="saveContainer" class="text-end mt-4 d-none">
                        <button type="submit" class="btn btn-primary px-5 py-3 fw-bold shadow-lg rounded-pill btn-lg transition-hover">
                            <i class="bi bi-save2-fill me-2"></i> GUARDAR CAMBIOS EN MATRIZ
                        </button>
                    </div>
                {% else %}
                    <div class="alert alert-warning mt-4 border-0 shadow-sm">
                        <i class="bi bi-lock-fill me-2"></i> No tienes permisos para modificar la matriz.
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const select = document.getElementById('selectPerfil');
            const body = document.getElementById('tablaPermisos');
            const saveContainer = document.getElementById('saveContainer');
            const hiddenId = document.getElementById('perfil_id_hidden');
            const loader = document.getElementById('loaderGlobal');
            const puedeEditar = {{ es_editor ? 'true' : 'false' }};

            select.addEventListener('change', function() {
                const id = this.value;
                hiddenId.value = id; // Sincronizamos el ID para el POST

                if (!id) {
                    body.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-muted italic">Seleccione un perfil...</td></tr>';
                    if(saveContainer) saveContainer.classList.add('d-none');
                    return;
                }

                // Mostrar Spinner
                loader.classList.remove('d-none');
                body.innerHTML = '<tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary"></div><br><small class="text-muted">Cargando datos desde Railway...</small></td></tr>';

                fetch(`/vistas/permisos/cargar/${id}`)
                    .then(r => r.json())
                    .then(data => {
                        loader.classList.add('d-none');
                        body.innerHTML = '';

                        if(data.length === 0) {
                            body.innerHTML = '<tr><td colspan="6" class="text-center py-4">No hay módulos vinculados.</td></tr>';
                            return;
                        }

                        data.forEach(p => {
                            const dis = puedeEditar ? '' : 'disabled';

                            // IMPORTANTE: Los nombres de los inputs deben coincidir con lo que recibe tu BulkUpdate
                            body.innerHTML += `
                            <tr class="transition-row">
                                <td class="fw-bold px-4 text-dark text-uppercase small">
                                    <i class="bi bi-layers-fill text-primary opacity-50 me-2"></i> ${p.modulo}
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input type="checkbox" name="permisos[${p.id}][boolAgregar]" class="form-check-input" ${p.agregar ? 'checked' : ''} ${dis}>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input type="checkbox" name="permisos[${p.id}][boolEditar]" class="form-check-input" ${p.editar ? 'checked' : ''} ${dis}>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input type="checkbox" name="permisos[${p.id}][boolEliminar]" class="form-check-input" ${p.eliminar ? 'checked' : ''} ${dis}>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input type="checkbox" name="permisos[${p.id}][boolConsultar]" class="form-check-input" ${p.consultar ? 'checked' : ''} ${dis}>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <i class="bi bi-check-circle-fill text-success opacity-25"></i>
                                </td>
                            </tr>`;
                        });

                        if(puedeEditar && saveContainer) saveContainer.classList.remove('d-none');
                    })
                    .catch(error => {
                        loader.classList.add('d-none');
                        console.error('Error:', error);
                        body.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-danger">Error al cargar la matriz.</td></tr>';
                    });
            });
        });
    </script>

    <style>
        .form-check-input { width: 2.5em; height: 1.25em; cursor: pointer; }
        .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
        .transition-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.15)!important; transition: 0.2s; }
        .transition-row:hover { background-color: rgba(13, 110, 253, 0.03)!important; }
        .italic { font-style: italic; }
    </style>
{% endblock %}
