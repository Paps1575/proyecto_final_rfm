{% extends 'base.html.twig' %}

{% block title %}Login - RFM{% endblock %}

{% block javascripts %}
    {# parent() asegura que no borre lo que haya en la base #}
    {{ parent() }}
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endblock %}

{% block body %}
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
        <div class="card border-0 shadow-sm rounded-4 p-4" style="max-width: 360px; width: 100%;">
            <div class="text-center mb-4">
                <h3 class="fw-bold text-dark mb-0" style="letter-spacing: 2px;">RFM</h3>
                <p class="text-muted small text-uppercase mb-0" style="letter-spacing: 3px; font-size: 0.7rem;">Productions</p>
            </div>

            <form method="post">
                {% if error %}
                    <div class="alert alert-danger py-2 small border-0 text-center mb-3">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div class="mb-3">
                    <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control bg-light border-0 py-2 text-center fw-bold" placeholder="USUARIO" required autofocus>
                </div>

                <div class="mb-4 position-relative">
                    <input type="password" name="_password" id="password" class="form-control bg-light border-0 py-2 text-center fw-bold" placeholder="CONTRASEÑA" required>
                </div>

                {# RECAPTCHA #}
                <div class="mb-3 d-flex justify-content-center">
                    <div class="g-recaptcha" data-sitekey="6Lf6M64sAAAAAKtngeT0SGCD-iCAvDlmfxZfUFce"></div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3 shadow-sm" style="background: #004a98; border: none;">INGRESAR</button>
            </form>
        </div>
    </div>

    <style>
        .g-recaptcha { transform: scale(0.85); transform-origin: 0 0; }
        .card { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
{% endblock %}
