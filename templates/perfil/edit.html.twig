{% extends 'base.html.twig' %}

{% block title %}Editar Perfil - Funes Mori Productions{% endblock %}

{% block body %}
    <div class="container mt-5">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent p-0">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}" class="text-decoration-none text-info">Inicio</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_perfil_index') }}" class="text-decoration-none text-info">Gestión de Perfiles</a></li>
                <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">Editar Perfil</li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-dark py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-white fw-bold">
                            <i class="bi bi-pencil-square text-info me-2"></i>
                            IDENTIDAD: <span class="text-info text-uppercase">{{ perfil.strNombrePerfil }}</span>
                        </h5>
                        <a href="{{ path('app_permiso_perfil_index') }}" class="btn btn-outline-info btn-sm fw-bold rounded-pill px-3">
                            <i class="bi bi-shield-lock-fill me-1"></i> MATRIZ
                        </a>
                    </div>

                    <div class="card-body p-4">
                        {{ form_start(form) }}
                        <div class="mb-4">
                            {{ form_label(form.strNombrePerfil, null, {'label_attr': {'class': 'form-label fw-bold text-secondary text-uppercase small'}}) }}
                            {{ form_widget(form.strNombrePerfil) }}
                        </div>

                        <div class="card bg-light border-0 rounded-3 mb-4">
                            <div class="card-body">
                                <div class="form-check form-switch">
                                    {{ form_widget(form.bitAdministrador) }}
                                    {{ form_label(form.bitAdministrador, null, {'label_attr': {'class': 'form-check-label fw-bold text-danger'}}) }}
                                </div>
                                <small class="text-muted d-block mt-2 italic">
                                    <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                                    Al ser Admin Total, se ignoran los checks de la matriz.
                                </small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a href="{{ path('app_perfil_index') }}" class="btn btn-link text-muted text-decoration-none p-0">
                                <i class="bi bi-arrow-left"></i> Volver al listado
                            </a>
                            <div class="btn-group">
                                <button type="submit" class="btn btn-info text-white px-4 fw-bold rounded-start-pill shadow-sm transition-hover">
                                    <i class="bi bi-save-fill me-2"></i> GUARDAR
                                </button>
                                <a href="{{ path('app_permiso_perfil_index') }}" class="btn btn-dark text-white px-4 fw-bold rounded-end-pill border-start border-info">
                                    PERMISOS <i class="bi bi-chevron-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .form-control:focus {
            border-color: #0dcaf0;
            box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.25);
        }
        .transition-hover:hover {
            transform: scale(1.03);
            transition: 0.2s;
        }
        .form-check-input:checked {
            background-color: #dc3545;
            border-color: #dc3545;
        }
    </style>
{% endblock %}
