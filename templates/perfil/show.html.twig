{% extends 'base.html.twig' %}

{% block title %}Detalle del Perfil: {{ perfil.strNombrePerfil }} - Rogelio Funes Mori Productions{% endblock %}

{% block body %}
    <div class="container-fluid mt-4">
        {# BREADCRUMBS LIMPIOS #}
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-white p-3 shadow-sm rounded-3 border">
                <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}" class="text-decoration-none text-info"><i class="bi bi-house-door-fill"></i> Inicio</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_perfil_index') }}" class="text-decoration-none text-info">Gestión de Perfiles</a></li>
                <li class="breadcrumb-item active fw-bold" aria-current="page">Ficha del Perfil</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0 border-top border-4 border-info rounded-3">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-dark">
                    <i class="bi bi-eye-fill text-info me-2"></i> Detalle del Perfil: <span class="text-primary text-uppercase">{{ perfil.strNombrePerfil }}</span>
                </h4>
                <div class="btn-group">
                    <a href="{{ path('app_perfil_index') }}" class="btn btn-outline-secondary btn-sm px-3 fw-bold">
                        <i class="bi bi-arrow-left"></i> VOLVER
                    </a>
                    <a href="{{ path('app_perfil_edit', {'id': perfil.id}) }}" class="btn btn-warning btn-sm px-3 fw-bold text-dark">
                        <i class="bi bi-gear-fill me-1"></i> CONFIGURAR MATRIZ
                    </a>
                </div>
            </div>

            <div class="card-body p-4">
                <div class="row g-4">
                    {# COLUMNA IZQUIERDA: INFO GENERAL #}
                    <div class="col-lg-4">
                        <div class="card border shadow-sm h-100">
                            <div class="card-header bg-light py-3">
                                <h6 class="mb-0 fw-bold text-uppercase small text-muted"><i class="bi bi-info-circle me-2"></i>Información General</h6>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush mb-4">
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <span class="text-muted small fw-bold">ID REGISTRO</span>
                                        <span class="badge bg-dark rounded-pill">#{{ perfil.id }}</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <span class="text-muted small fw-bold">NOMBRE</span>
                                        <span class="text-primary fw-bold text-uppercase">{{ perfil.strNombrePerfil }}</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <span class="text-muted small fw-bold">ESTADO</span>
                                        <span class="badge bg-success-subtle text-success border border-success px-3">ACTIVO</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <span class="text-muted small fw-bold">USUARIOS</span>
                                        <span class="text-dark fw-bold"><i class="bi bi-people-fill text-info"></i> {{ perfil.usuarios|length }}</span>
                                    </li>
                                </ul>

                                {# ELIMINAR NORMAL (SIN CHINGADERAS DE PELIGRO) #}
                                {% if perfil.id != 7 %}
                                    <form method="post" action="{{ path('app_perfil_delete', {'id': perfil.id}) }}" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este perfil? Esta acción no se puede deshacer.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ perfil.id) }}">
                                        <button class="btn btn-outline-danger btn-sm w-100 py-2">
                                            <i class="bi bi-trash3 me-1"></i> ELIMINAR REGISTRO
                                        </button>
                                    </form>
                                {% else %}
                                    <div class="alert alert-secondary text-center py-2 mb-0">
                                        <i class="bi bi-lock-fill me-1"></i> Perfil Protegido
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# COLUMNA DERECHA: MATRIZ DE ACCESOS #}
                    <div class="col-lg-8">
                        <div class="card border shadow-sm h-100">
                            <div class="card-header bg-dark text-white py-3">
                                <h6 class="mb-0 fw-bold small text-uppercase italic">
                                    <i class="bi bi-key-fill me-2 text-info"></i>Matriz de Permisos por Módulo
                                </h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                    <tr class="text-center small text-uppercase text-muted">
                                        <th class="text-start ps-4 py-3">Módulo</th>
                                        <th>Consultar</th>
                                        <th>Agregar</th>
                                        <th>Editar</th>
                                        <th>Eliminar</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for permiso in perfil.permisoPerfils %}
                                        <tr class="text-center">
                                            <td class="text-start ps-4 fw-bold text-secondary">
                                                <i class="bi bi-caret-right-fill text-info me-1"></i>
                                                {{ permiso.modulo.strNombre|upper }}
                                            </td>
                                            <td>{{ permiso.boolConsultar ? '<i class="bi bi-check-circle-fill text-success fs-5"></i>' : '<i class="bi bi-x-circle text-danger opacity-25 fs-5"></i>' }}</td>
                                            <td>{{ permiso.boolAgregar ? '<i class="bi bi-check-circle-fill text-success fs-5"></i>' : '<i class="bi bi-x-circle text-danger opacity-25 fs-5"></i>' }}</td>
                                            <td>{{ permiso.boolEditar ? '<i class="bi bi-check-circle-fill text-success fs-5"></i>' : '<i class="bi bi-x-circle text-danger opacity-25 fs-5"></i>' }}</td>
                                            <td>{{ permiso.boolEliminar ? '<i class="bi bi-check-circle-fill text-success fs-5"></i>' : '<i class="bi bi-x-circle text-danger opacity-25 fs-5"></i>' }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white text-end py-2 border-top">
                <small class="text-muted italic">Funes Mori Productions &copy; 2026</small>
            </div>
        </div>
    </div>

    <style>
        .italic { font-style: italic; }
        .table-hover tbody tr:hover { background-color: rgba(13, 202, 240, 0.03); }
    </style>
{% endblock %}
