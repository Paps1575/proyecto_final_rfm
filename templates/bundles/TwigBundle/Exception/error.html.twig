{% extends 'base.html.twig' %}

{% block title %}Error en el Sistema{% endblock %}

{% block body %}
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="max-width: 500px;">
            <div class="card-body p-5 text-center">
                <div class="mb-4 text-danger">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 4rem;"></i>
                </div>
                <h2 class="fw-bold text-dark">¡UPS! ALGO SALIÓ MAL</h2>
                <p class="text-muted">Hubo un error interno en el servidor. El equipo de **Rogelio Funes Mori Productions** ya está trabajando en ello.</p>
                <div class="bg-light p-3 rounded-3 mb-4">
                    <small class="text-secondary fw-bold text-uppercase">Código de Error: 500 / Internal Server Error</small>
                </div>
                <a href="{{ path('app_dashboard') }}" class="btn btn-dark w-100 py-3 fw-bold rounded-3">
                    VOLVER A INICIO
                </a>
            </div>
        </div>
    </div>
{% endblock %}
